{
  "version_scope": "0.9.0rc5",
  "current_public_prerelease": "v0.9.0rc4",
  "open_source_solver_first": true,
  "examples": [
    {
      "path": "examples/specs/minimal_nanoparticle.json",
      "purpose": "minimal valid offline spec",
      "commands": [
        "optical-spec validate examples/specs/minimal_nanoparticle.json",
        "optical-spec parse examples/specs/minimal_nanoparticle.json"
      ],
      "requires_network": false,
      "requires_external_solver": false,
      "requires_external_llm": false,
      "requires_proprietary_solver": false
    },
    {
      "path": "examples/specs/missing_wavelength_meep_preview.json",
      "purpose": "Meep preview diagnostics for missing wavelength defaults",
      "commands": [
        "optical-spec adapter-generate examples/specs/missing_wavelength_meep_preview.json --tool meep --json"
      ],
      "requires_network": false,
      "requires_external_solver": false,
      "requires_external_llm": false,
      "requires_proprietary_solver": false
    },
    {
      "path": "examples/workflows/local_preview_request.json",
