{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meep Manual Validation Report",
  "type": "object",
  "required": [
    "date",
    "maintainer",
    "project_version",
    "git_commit",
    "adapter_family",
    "solver_name",
    "solver_version",
    "solver_available",
    "validation_enabled",
    "input_fixture",
    "generated_artifact",
    "command_run",
    "expected_high_level_result",
    "observed_result",
    "diagnostics",
    "passed",
    "limitations",
    "production_grade_validation_claimed",
    "formal_convergence_proof_claimed",
    "release_note_claim_supported"
  ],
  "properties": {
    "date": { "type": "string" },
    "maintainer": { "type": "string" },
    "project_version": { "type": "string" },
    "git_commit": { "type": "string" },
    "adapter_family": { "const": "meep" },
    "solver_name": { "const": "Meep" },
    "solver_version": { "type": "string" },
    "solver_available": { "type": "boolean" },
    "validation_enabled": { "type": "boolean" },
    "input_fixture": { "type": "string" },
    "generated_artifact": { "type": "string" },
    "command_run": { "type": "string" },
    "expected_high_level_result": { "type": "string" },
    "observed_result": { "type": "string" },
    "diagnostics": { "type": "string" },
    "passed": { "type": "boolean" },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "production_grade_validation_claimed": { "const": false },
    "formal_convergence_proof_claimed": { "const": false },
    "release_note_claim_supported": { "type": "string" }
  },
  "additionalProperties": true
}
